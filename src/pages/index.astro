---
import '../styles/global.css';
const LANGS = ['vietnamese', 'english'];
---
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SubVault</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-slate-100">
    <header class="border-b border-slate-800 p-4">
      <h1 class="text-xl font-bold">SubVault</h1>
      <input id="q" type="search" placeholder="Search titles…" autocomplete="off"
        class="mt-3 w-full rounded-lg border border-slate-700 bg-slate-800 px-3 py-2" />
      <div class="mt-3 flex flex-wrap items-center gap-3 text-sm">
        <span class="text-slate-400">Language:</span>
        {LANGS.map((l) => (
          <label class="flex items-center gap-1">
            <input type="checkbox" name="lang" value={l} /> {l}
          </label>
        ))}
        <select id="f-type" class="rounded border border-slate-700 bg-slate-800 px-2 py-1">
          <option value="">All types</option>
          <option value="movie">Movie</option>
          <option value="tv">TV</option>
          <option value="unknown">Unknown</option>
        </select>
        <input id="f-from" type="number" placeholder="From yr" class="w-24 rounded border border-slate-700 bg-slate-800 px-2 py-1" />
        <input id="f-to" type="number" placeholder="To yr" class="w-24 rounded border border-slate-700 bg-slate-800 px-2 py-1" />
      </div>
    </header>
    <main class="p-4">
      <div class="mb-3 flex items-center gap-3 text-sm">
        <button id="prev" class="rounded bg-slate-700 px-3 py-1 disabled:opacity-40">Prev</button>
        <button id="next" class="rounded bg-slate-700 px-3 py-1 disabled:opacity-40">Next</button>
        <span id="page-info" class="text-slate-400"></span>
      </div>
      <div id="results" class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"></div>
    </main>
    <script>
      import '../islands/search.ts';
    </script>
  </body>
</html>
