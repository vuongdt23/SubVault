---
import '../styles/global.css';
const LANGS = ['vietnamese', 'english'];
// Bounds of the year range slider (matches deriveYear's plausible 1900–2029).
const YEAR_MIN = 1930;
const YEAR_MAX = 2029;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SubVault — Subtitle Archive</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <!-- top letterbox bar -->
    <div class="h-2 w-full shrink-0 bg-black"></div>

    <header class="w-full px-8 pt-10 lg:px-16">
      <div class="flex items-end justify-between gap-6">
        <div>
          <p class="eyebrow rise">Est. Archive · {LANGS.length} languages indexed</p>
          <h1 class="font-display mt-2 rise text-5xl font-semibold leading-none tracking-tight sm:text-6xl">
            Sub<span style="color: var(--color-amber)">Vault</span>
          </h1>
          <p class="mt-3 max-w-md rise text-sm" style="color: var(--color-muted); animation-delay: 0.08s">
            A projection room for subtitles — search the archive, cross-referenced
            across every language, and pull the reel you need.
          </p>
        </div>
        <div class="hidden shrink-0 text-right sm:block rise" style="animation-delay: 0.12s">
          <div class="font-mono text-xs" style="color: var(--color-faint)">REEL INDEX</div>
          <div class="font-display text-3xl" style="color: var(--color-amber-soft)" id="stat-count">—</div>
          <div class="font-mono text-xs" style="color: var(--color-faint)">titles on file</div>
        </div>
      </div>

      <!-- search -->
      <div class="searchbar mt-8 rise" style="animation-delay: 0.16s">
        <span class="glyph">⌕</span>
        <input id="q" type="search" placeholder="Search the archive…" autocomplete="off" class="search-input" />
      </div>

      <!-- filters -->
      <div class="mt-4 flex flex-wrap items-center gap-2.5 rise" style="animation-delay: 0.2s">
        <span class="eyebrow mr-1">Filter</span>
        <select id="f-lang" class="field capitalize">
          <option value="">All languages</option>
          {LANGS.map((l) => <option value={l}>{l}</option>)}
        </select>
        <select id="f-type" class="field">
          <option value="">All types</option>
          <option value="movie">Movie</option>
          <option value="tv">TV</option>
          <option value="unknown">Unknown</option>
        </select>
        <div class="yrbox" data-min={YEAR_MIN} data-max={YEAR_MAX}>
          <span class="yrbox-label">Year</span>
          <input id="yr-lo" class="yrbox-input" type="number" inputmode="numeric" min={YEAR_MIN} max={YEAR_MAX} placeholder="from" aria-label="From year" />
          <span class="yrbox-sep">—</span>
          <input id="yr-hi" class="yrbox-input" type="number" inputmode="numeric" min={YEAR_MIN} max={YEAR_MAX} placeholder="to" aria-label="To year" />
        </div>
        <button id="f-clear" class="btn" type="button">Clear</button>
      </div>

      <div class="hair mt-8"></div>
    </header>

    <main class="stage w-full flex-1 px-8 pb-16 lg:px-16">
      <div class="mb-6 mt-5 flex items-center gap-4">
        <button id="prev" class="btn" disabled>← Prev</button>
        <button id="next" class="btn">Next →</button>
        <span id="page-info" class="count-note ml-auto"></span>
      </div>
      <div id="results" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 min-[1800px]:grid-cols-6"></div>
    </main>

    <footer class="w-full shrink-0 px-8 pb-8 pt-6 lg:px-16">
      <div class="hair mb-5"></div>
      <div class="flex flex-wrap items-center justify-between gap-3">
        <span class="eyebrow">SubVault · Projection Room</span>
        <span class="count-note">Subscene Final archive · served locally</span>
      </div>
    </footer>

    <script>
      import '../islands/search.ts';
    </script>
  </body>
</html>
